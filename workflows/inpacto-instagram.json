      "id": "a1b2c3d4-0001-4000-8000-000000000020",
      "name": "Posts Instagram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        300
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const v = (d, key) => {\n  if (!d) return 0;\n  let raw = d[key];\n  if (raw === undefined || raw === null) return 0;\n  if (typeof raw === 'object' && raw.value !== undefined) raw = raw.value;\n  if (typeof raw === 'string') return parseFloat(raw.replace(',', '.')) || 0;\n  return Number(raw) || 0;\n};\n\nconst allItems = $input.all();\nconst allPeriods = $('Calcular Periodo').all();\nconst results = [];\n\nfor (let i = 0; i < allItems.length; i++) {\n  const input = allItems[i].json;\n  const posts = (input.data && input.data.posts) || (Array.isArray(input.data) ? input.data : (input.data && input.data.items || [])) || input.posts || [];\n  const periodDate = allPeriods[i].json.periodDate;\n\n  for (const post of (Array.isArray(posts) ? posts : [])) {\n    if (!post || !post.id) continue;\n    const kpi = post.kpi || post;\n    let postDate = periodDate;\n    if (post.date) {\n      const parsed = new Date(post.date);\n      if (!isNaN(parsed)) {\n        const y = parsed.getUTCFullYear();\n        const m = String(parsed.getUTCMonth() + 1).padStart(2, '0');\n        const d = String(parsed.getUTCDate()).padStart(2, '0');\n        postDate = `${y}-${m}-${d}`;\n      }\n    }\n    results.push({ json: {\n      platform: 'instagram', external_id: post.id, date: postDate,\n      formato: post.type || 'OUTRO',\n      titulo: (post.message || '').substring(0, 500),\n      thumbnail_url: ((post.image || '').startsWith('http') ? (post.image || '') : ''),\n      permalink: post.link || '',\n      visualizacoes: v(kpi, 'page_post_impressions_organic') || v(kpi, 'profile_post_crossposted_views'),\n      curtidas: v(kpi, 'page_posts_likes_count') || v(kpi, 'profile_likes_count_total'),\n      comentarios: v(kpi, 'page_posts_comments_count') || v(kpi, 'profile_comments_count_total'),\n      compartilhamentos: v(kpi, 'page_posts_shares_count'),\n      salvamentos: v(kpi, 'profile_post_saved'),\n      alcance: v(kpi, 'page_posts_impressions_organic_unique'),\n      reactions: Math.round(v(kpi, 'profile_post_total_interactions')),\n      tipo_post: post.type || 'OUTRO'\n    } });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { _empty: true } }];"
      },
