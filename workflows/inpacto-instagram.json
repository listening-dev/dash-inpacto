    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const allItems = $input.all();\nconst results = [];\n\nfor (const item of allItems) {\n  const data = item.json;\n  const publicUrl = `https://SUPABASE_URL_AQUI.supabase.co/storage/v1/object/public/posts_images/instagram/${data.external_id}.jpg`;\n  results.push({ json: { ...data, thumbnail_url: publicUrl } });\n}\n\nreturn results;"
      },
