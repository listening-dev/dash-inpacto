      "parameters": {
        "method": "POST",
        "url": "https://SUPABASE_URL_AQUI.supabase.co/rest/v1/daily_metrics?on_conflict=platform,date",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "ANON_KEY_AQUI"
            },
            {
              "name": "Authorization",
              "value": "Bearer SERVICE_ROLE_KEY_AQUI"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Content-Profile",
              "value": "inpacto"
            },
            {
              "name": "Accept-Profile",
              "value": "inpacto"
            },
            {
              "name": "Prefer",
              "value": "resolution=merge-duplicates,return=minimal"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000012",
      "name": "Supabase daily_metrics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
