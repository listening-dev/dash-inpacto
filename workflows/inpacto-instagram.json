    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const v = (d, key) => {\n  if (!d) return 0;\n  let raw = d[key];\n  if (raw === undefined || raw === null) return 0;\n  if (typeof raw === 'object' && raw.value !== undefined) raw = raw.value;\n  if (typeof raw === 'string') return parseFloat(raw.replace(',', '.')) || 0;\n  return Number(raw) || 0;\n};\n\nconst allItems = $input.all();\nconst allPeriods = $('Calcular Periodo').all();\nconst results = [];\n\nfor (let i = 0; i < allItems.length; i++) {\n  const input = allItems[i].json;\n  const data = input.data || input;\n  const stories = (input.data && (input.data.stories || input.data.posts || input.data.items)) || (Array.isArray(data) ? data : (data.stories || data.items || []));\n  const periodDate = allPeriods[i].json.periodDate;\n\n  for (const story of (Array.isArray(stories) ? stories : [])) {\n    if (!story) continue;\n    const kpi = story.kpi || story;\n    const externalId = story.id || story.link || `story_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`;\n    results.push({ json: {\n      platform: 'instagram', external_id: externalId, date: periodDate,\n      media_type: story.type || 'STORY',\n      thumbnail_url: story.image || '',\n      permalink: story.link || '',\n      impressoes: v(kpi, 'profile_story_impressions'),\n      alcance: v(kpi, 'profile_story_reach'),\n      respostas: v(kpi, 'profile_story_replies'),\n      saidas: v(kpi, 'profile_story_exits'),\n      toques_frente: v(kpi, 'profile_story_taps_forward'),\n      toques_atras: v(kpi, 'profile_story_taps_back')\n    } });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { _empty: true } }];"
      },
