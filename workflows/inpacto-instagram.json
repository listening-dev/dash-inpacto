    {
      "parameters": {
        "method": "GET",
        "url": "https://app.fanpagekarma.com/api/v1/instagram/PROFILE_ID_AQUI/posts",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "TOKEN_AQUI"
            },
            {
              "name": "period",
              "value": "={{ $json.period }}"
