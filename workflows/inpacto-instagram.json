    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Calcula o periodo = ontem\nconst now = new Date();\nnow.setDate(now.getDate() - 1);\nconst yyyy = now.getFullYear();\nconst mm = String(now.getMonth() + 1).padStart(2, '0');\nconst dd = String(now.getDate()).padStart(2, '0');\n\nconst periodDate = `${yyyy}-${mm}-${dd}`;\nconst period = `${periodDate}_${periodDate}`;\n\nreturn {\n  json: {\n    periodDate,\n    period\n  }\n};"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000002",
      "name": "Calcular Periodo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://app.fanpagekarma.com/api/v1/instagram/PROFILE_ID_AQUI/kpi",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "token",
              "value": "TOKEN_AQUI"
            },
            {
              "name": "period",
              "value": "={{ $json.period }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000010",
      "name": "KPI Instagram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        500,
        0
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const v = (d, key) => {\n  if (!d) return 0;\n  let raw = d[key];\n  if (raw === undefined || raw === null) return 0;\n  if (typeof raw === 'object' && raw.value !== undefined) raw = raw.value;\n  if (typeof raw === 'string') return parseFloat(raw.replace(',', '.')) || 0;\n  return Number(raw) || 0;\n};\nconst vnn = (d, key) => Math.max(0, v(d, key));\n\nconst allItems = $input.all();\nconst allPeriods = $('Calcular Periodo').all();\nconst results = [];\n\nfor (let i = 0; i < allItems.length; i++) {\n  const input = allItems[i].json;\n  const data = input.data || input;\n  const periodDate = allPeriods[i].json.periodDate;\n  results.push({ json: {\n    platform: 'instagram', date: periodDate,\n    visualizacoes: vnn(data, 'profile_meta_views') || vnn(data, 'media_views'),\n    alcance: vnn(data, 'profile_reach'),\n    interacoes: vnn(data, 'profile_total_interactions'),\n    novos_seguidores: v(data, 'profile_followers_growth_absolute'),\n    total_seguidores: vnn(data, 'profile_followers'),\n    visitas_perfil: vnn(data, 'profile_profile_views'),\n    cliques_link: vnn(data, 'profile_website_clicks'),\n    posts_count: vnn(data, 'profile_media_count'),\n    curtidas_total: vnn(data, 'profile_in_likes_on_day')\n  } });\n}\n\nreturn results;"
      },
      "id": "a1b2c3d4-0001-4000-8000-000000000011",
      "name": "Formatar Metricas",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        740,
